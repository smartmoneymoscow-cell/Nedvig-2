# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estate_auction
DB_USER=postgres
DB_PASSWORD=postgres

# Yandex Maps API key (get at https://developer.tech.yandex.ru/)
YANDEX_MAPS_API_KEY=

# Proxy list (comma-separated)
# Format: http://user:pass@host:port,socks5://host:port
PROXY_LIST=

# Scraping intervals
SCRAPE_INTERVAL_HOURS=6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
