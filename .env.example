# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estate_auction
DB_USER=postgres
DB_PASSWORD=postgres

# Proxy list (comma-separated)
# Format: http://user:pass@host:port,socks5://host:port
PROXY_LIST=

# Scraping intervals
SCRAPE_INTERVAL_HOURS=6

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Security (REQUIRED in production — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
ADMIN_API_KEY=
JWT_SECRET=
CORS_ORIGINS=https://smartmoneymoscow-cell.github.io

# Yandex Maps API key (optional — app uses OpenStreetMap by default)
YANDEX_MAPS_API_KEY=

# Scraper Worker URL (for API to trigger scrapes)
SCRAPER_WORKER_URL=http://localhost:8001
